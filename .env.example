## Trading Mode
## production = real OKX data only, no fallback/demo/mock
## demo       = static demo data for local development
APP_TRADING_MODE=production

## Chain config (X Layer defaults — change for Base or other chains)
OKX_CHAIN_INDEX=196
OKX_CHAIN_NAME=X Layer
OKX_CHAIN_SLUG=xlayer

## Default source token for swap quotes (USDC on X Layer)
## P0 default — not a product limitation. Custom fromToken supported in future.
OKX_DEFAULT_FROM_TOKEN=0x74b7f16337b8972027f6196a17a631ac6de26d22
OKX_DEFAULT_FROM_SYMBOL=USDC

## OKX API credentials (used by onchainos CLI — must be set for production mode)
## Get your keys at: https://web3.okx.com/onchain-os/dev-portal
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=
OKX_WALLET_ADDRESS=

## Optional: Claude API for thesis parsing (falls back to keyword parser if absent)
ANTHROPIC_API_KEY=
# Use claude-sonnet-4-5-20250929 for best performance in production
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

## Privy wallet authentication and ownership verification
## Get credentials at: https://dashboard.privy.io
## Both are REQUIRED for production wallet ownership verification.
## Without these, dev mode uses passthrough auth (unsafe, clearly marked).
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

## Postgres persistence (required for live execution audit trail)
## Example: postgres://user:password@localhost:5432/phylax
DATABASE_URL=

## Redis (required for live execution: replay protection, kill switch, rate limits)
## Example: redis://localhost:6379
REDIS_URL=

## RPC URLs for transaction confirmation (optional, falls back to public RPCs)
## Format: RPC_URL_{chainId}
# RPC_URL_1=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_URL_8453=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_URL_196=https://rpc.xlayer.tech

## Execution control
## ENABLE_LIVE_EXECUTION=false → no transaction broadcast, quote/risk are real
## ENABLE_LIVE_EXECUTION=true  → returns unsigned tx for browser wallet signing
## Requires: DATABASE_URL, REDIS_URL, Privy credentials
ENABLE_LIVE_EXECUTION=false

## Next.js public (safe to expose — no secrets)
NEXT_PUBLIC_APP_NAME=PhylaX
NEXT_PUBLIC_DEFAULT_CHAIN=xlayer
NEXT_PUBLIC_DATA_MODE=real
NEXT_PUBLIC_APP_TRADING_MODE=production
NEXT_PUBLIC_ENABLE_LIVE_EXECUTION=false
