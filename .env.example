## Trading Mode
## production = real OKX data only, no fallback/demo/mock
## demo       = static demo data for local development
APP_TRADING_MODE=production

## Supported Chains: X Layer (196), Base (8453), and BSC (56) are the supported EVM live chains.
## Solana is not supported in the EVM execution path yet.
## Note: OKX_CHAIN_INDEX must not be treated as the runtime chain selector if Phase 6 canonical chain config is used.
OKX_CHAIN_INDEX=196
OKX_CHAIN_NAME=X Layer
OKX_CHAIN_SLUG=xlayer

## Default source token for swap quotes (USDC on X Layer)
OKX_DEFAULT_FROM_TOKEN=0x74b7f16337b8972027f6196a17a631ac6de26d22
OKX_DEFAULT_FROM_SYMBOL=USDC

## OKX API credentials (used by onchainos CLI)
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=
OKX_WALLET_ADDRESS=

## Optional: Claude API for thesis parsing
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

## Privy wallet authentication
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

## Postgres persistence
DATABASE_URL=

## Redis
REDIS_URL=

## Security Secrets
ADMIN_SECRET=
APPROVAL_SECRET=

## Risk Policy
MAX_TRADE_USD_HARD_CAP=1

## RPC URLs for transaction confirmation
## Format: RPC_URL_{chainId}
# RPC_URL_196=https://rpc.xlayer.tech
# RPC_URL_8453=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_URL_56=https://bsc-dataseed.binance.org/

## Execution control
ENABLE_LIVE_EXECUTION=false

## Next.js public
NEXT_PUBLIC_APP_NAME=PhylaX
NEXT_PUBLIC_DEFAULT_CHAIN=xlayer
NEXT_PUBLIC_DATA_MODE=real
NEXT_PUBLIC_APP_TRADING_MODE=production
NEXT_PUBLIC_ENABLE_LIVE_EXECUTION=false
